# Bridge root — MUST match `messenger-bridge-directory' in messenger-bridge.el
MESSENGER_BRIDGE_DIR=/Users/you/.emacs.d/messenger-bridge

# Where Baileys stores the WhatsApp session (created on first QR login)
WA_AUTH_DIR=./auth

# SAFETY whitelist: comma-separated WhatsApp JIDs whose inbound messages are
# relayed into the bridge. Leave empty on first run, message the number from
# your phone, read the printed sender JID, then put it here.
# Example: WA_ALLOWED_JIDS=491701234567@s.whatsapp.net
WA_ALLOWED_JIDS=

# Outbox poll interval (ms)
WA_POLL_MS=500

# Relay your own "Note to Self" chat as inbound (a handy coach channel).
# true (default) = yes; false = ignore your own self-chat.
WA_RELAY_SELF=true

# Export the contact list (name->JID) to <bridge>/contacts.json for name
# resolution by the agent. true (default) = export; false = off.
WA_EXPORT_CONTACTS=true
